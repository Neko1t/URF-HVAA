# ========================
# 1. 数据集与多媒体文件 (最关键)
# ========================
# 数据集
data/
*.mp4
*.avi
*.mkv
*.jpg
*.jpeg
*.png
*.7z
*.zip
*.tar.gz

# ========================
# 2. 模型权重文件
# ========================
# 之前提到的十几个 G 的 Llama 模型以及你跑出来的 checkpoint 绝对不能传
*.pth
*.pt
*.ckpt
*.bin
*.safetensors
# 大模型权重文件
libs/llama/llama3.1-8b/
libs/VideoLLaMA3-7B/

# ========================
# 3. 本地编辑器与环境配置
# ========================
# 截图里看到的 .vscode 文件夹，里面是你本地编辑器的个性化设置，不应该同步给别人
.vscode/
.idea/

# ========================
# 4. Python 运行缓存
# ========================
# Python 运行自动生成的字节码缓存，没必要同步
__pycache__/
*.py[cod]
*$py.class

# ========================
# 5. 日志与实验结果
# ========================
# 跑代码产生的 log 和临时输出，每天都在变
*.log
logs/
outputs/
results/


# 忽略 Jupyter 自动生成的备份文件夹
.ipynb_checkpoints/